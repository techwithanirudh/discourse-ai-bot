# Discourse Credentials
# Get these from your Discourse Forum

# Bot API Key from Admin > API Keys
DISCOURSE_BOT_TOKEN=your-bot-api-key
# Discourse username of the bot account (default: zenix)
DISCOURSE_BOT_USERNAME=zenix
DISCOURSE_URL=https://community.yourdomain.com/
# Signing Secret from the Webhook settings
DISCOURSE_SIGNING_SECRET=your-signing-secret

# OpenAI Credentials
# Get this from your OpenAI account at https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key
EXA_API_KEY=your-exa-api-key